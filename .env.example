# 复制为 .env 使用。两段:本地开发(app/seed bin 经 dotenvy 读) + docker compose(${VAR} 替换)。

# ===== 本地开发(cargo run / just dev)=====

# 监听地址(默认 0.0.0.0:8080)
BIND_ADDR=0.0.0.0:8137

# 限流(按 IP,opt-in)。不设 = 关。RATE_LIMIT_ENABLED=true 才启用,其余是每 IP 令牌桶参数。
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_SEC=10
RATE_LIMIT_BURST=20

# Prometheus /metrics 端点(opt-in)。不设 = 关。
METRICS_ENABLED=true

# 信任的反向代理层数(默认 1 = 单层 nginx)。真实客户端 IP 从 X-Forwarded-For 右数第 (N+1)
# 跳取值(防伪造最左);审计 IP 与限流键都用它。**直连暴露(前面没反代)必须设 0**,否则
# 客户端自造的单条 XFF 会被当可信;nginx + CDN 两层则设 2。
TRUSTED_PROXY_HOPS=1

# app schema 数据库(role=app)。设 APP_DB_HOST 即启用 pg;不设 = widget 走内存(脚手架默认)。
# 其余字段有默认值:port 5432 / database baserust / user app / password pwd / sslmode disable。
# dev 连本地 compose pg 用:APP_DB_HOST=localhost + APP_DB_PORT=5821。
APP_DB_HOST=localhost
APP_DB_PORT=5821
APP_DB_DATABASE=baserust
APP_DB_SSLMODE=disable

# idm schema 数据库(role=idm)。设 IDM_DB_HOST 即 idm 走 pg(读 seed 的 superadmin 等);不设 = 内存。
# 字段默认:port 5432 / database baserust / user idm / password pwd / sslmode disable。
IDM_DB_HOST=localhost
IDM_DB_PORT=5821
IDM_DB_DATABASE=baserust
IDM_DB_SSLMODE=disable

# JWT 签验密钥(Ed25519,非对称)。不设 = 内嵌 dev 密钥对(keys/,仅供开发,prod 启动期拒用)。
# 生产用 `just gen-keys` 造新对:idm 进程两个都设,app 进程只设公钥(app 被攻破铸不出 token)。
JWT_PRIVATE_KEY_FILE=./keys/prod-ed25519.pem
JWT_PUBLIC_KEY_FILE=./keys/prod-ed25519.pub.pem

# token 有效期(秒)。access 默认 900(15min)、refresh 默认 604800(7天)。
IDM_ACCESS_TTL_SECS=900
IDM_REFRESH_TTL_SECS=604800

# 进程内启动 seed 账号(幂等)。不设时:非 prod → seed(嵌入默认账号);
# prod → 仅当挂了 SEED_FILE(真密码,见下)才 seed,否则不建号。显式设则永远优先。
IDM_SEED_ON_START=true

# content schema 数据库(role=content)。设 CONTENT_DB_HOST 即 content/object 元数据走 pg;不设 = 内存。
# 字段默认:port 5432 / database baserust / user content / password pwd / sslmode disable。
CONTENT_DB_HOST=localhost
CONTENT_DB_PORT=5821
CONTENT_DB_DATABASE=baserust
CONTENT_DB_SSLMODE=disable

# search schema 数据库(role=search)。设 SEARCH_DB_HOST 即启用 CQRS 投影读模型
# (projector 落 admin_user_index;后台用户列表的 q 模糊搜 + display_name 排序走它);
# 不设 = 无投影(列表回退直查 idm,不支持这两项)。字段默认:port 5432 / database baserust /
# user search / password pwd / sslmode disable。
SEARCH_DB_HOST=localhost
SEARCH_DB_PORT=5821
SEARCH_DB_DATABASE=baserust
SEARCH_DB_SSLMODE=disable

# 对象存储(content 的字节后端;元数据进上面的 pg)。设 S3_ENDPOINT 即走 minio/S3;不设 = 内存 backend。
# dev 连本地 compose minio 用主机端口:http://localhost:9862(即 MINIO_PORT)。
# 单域名要求:启用 presign(preview/download 307)时,S3_ENDPOINT 必须**浏览器可达**
# (host dev 用 localhost:9862 即可;compose 见 docker-compose.yml 的 minio.localhost 方案)。
# 其余默认:bucket content / access minio / secret minio12345 / region us-east-1(与 compose minio 对齐)。
S3_ENDPOINT=http://localhost:9862
S3_BUCKET=content
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio12345
S3_REGION=us-east-1
# presign URL 形态。默认 false = 绝对 URL(浏览器直连 minio;dev/单域名)。
# true = 相对 URL(浏览器经 nginx 反代;prod 边缘 TLS、只开 80)。true 时 S3_ENDPOINT 应指内网。
S3_PRESIGN_RELATIVE=false

# widget 事件总线(SSE)。选择链:设 NATS_URL → NATS(多实例默认);没设有 APP_DB_HOST → PG
# LISTEN/NOTIFY 退路;都没有 → 内存(单实例)。dev 连本地 compose nats 用主机端口 NATS_PORT(默认 2224)。
NATS_URL=nats://localhost:2224

# 日志级别(tracing EnvFilter)。不设 = dev 默认 debug 全开。
# 注意:放进 .env 会同时影响本地 app(dotenvy 读它),想保留 dev debug 就别在 .env 设。
RUST_LOG=info,baserust=debug

# 文件日志路径。不设 = 只 stdout(容器/生产)。dev 设成 logs/dev.log 即可在文件观察。
LOG_FILE=logs/dev.log

# app 进程是否内嵌 idm。默认 true(单进程 Both);生产分进程设 false → 只挂 app。只认小写 true/false。
IDM_EMBEDDED=true

# seed / mock 数据文件覆盖。不设 = 用编译期嵌入的 seed.toml / mock.toml。
# prod:挂真账号文件(cp seed.prod.toml.example seed.prod.toml 填强密码)+ 设 SEED_FILE 指向容器内路径,
# idm 进程启动即建号(compose.prod 已挂 /seed/seed.prod.toml)。设了 SEED_FILE 即启用 prod seed。
SEED_FILE=seed.toml
MOCK_FILE=mock.toml

# ===== docker compose =====
# compose 用这些做 ${VAR} 替换,都有默认值(不设也能 up)。

# 运行环境:dev(默认)/staging/prod。prod → JSON 日志 + 不挂 /docs + CORS 走白名单。
APP_ENV=dev
# prod CORS 允许的源(逗号分隔);dev/staging 走 permissive 不读此项。
CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com

# pg 超级用户(dbhub DSN 引用;initdb 用它创建各 schema 的 role)
POSTGRES_USER=baserust
POSTGRES_PASSWORD=baserust
POSTGRES_DB=baserust

# 各 schema 的 role(名 = schema 名)与密码,各走独立变量;密码暂统一 pwd。
# app 容器与迁移都用对应 role 连接(role 的 search_path 指向同名 schema,不写 schema 前缀)。
# *_DB_DATABASE = 各进程连库的库名(= POSTGRES_DB)。host app(just dev)也从这拿,
# 不设则退 config.rs 编译默认(baserust)—— 显式钉上避免默认与 POSTGRES_DB 漂移。
APP_DB_USER=app
APP_DB_PASSWORD=pwd
APP_DB_DATABASE=baserust
IDM_DB_USER=idm
IDM_DB_PASSWORD=pwd
IDM_DB_DATABASE=baserust
CONTENT_DB_USER=content
CONTENT_DB_PASSWORD=pwd
CONTENT_DB_DATABASE=baserust
SEARCH_DB_USER=search
SEARCH_DB_PASSWORD=pwd
SEARCH_DB_DATABASE=baserust

# minio 凭据与桶名(compose 的 minio/minio-init 服务 + app 的 S3_ACCESS_KEY/S3_SECRET_KEY 都取这)
MINIO_USER=minio
MINIO_PASSWORD=minio12345
S3_BUCKET=content
# minio API 的 CORS 允许源(浏览器直连 presign 时才需要;默认 * 宽松,prod 收紧到前端域)。
MINIO_CORS_ORIGIN=*

# 主机映射端口
APP_PORT=6453
IDM_PORT=6454
DBHUB_PORT=3777
PG_PORT=5821
NGINX_PORT=80
MINIO_PORT=9862
MINIO_CONSOLE_PORT=9863
NATS_PORT=2224
