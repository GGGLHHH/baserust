# 复制为 .env 使用。两段:本地开发(app/seed bin 经 dotenvy 读) + docker compose(${VAR} 替换)。

# ===== 本地开发(cargo run / just dev)=====

# 监听地址(默认 0.0.0.0:8080)
# BIND_ADDR=0.0.0.0:8137

# app schema 数据库(role=app)。设 APP_DB_HOST 即启用 pg;不设 = widget 走内存(脚手架默认)。
# 其余字段有默认值:port 5432 / database xchangeai / user app / password pwd / sslmode disable。
# dev 连本地 compose pg 用:APP_DB_HOST=localhost + APP_DB_PORT=5821。
# APP_DB_HOST=localhost
# APP_DB_PORT=5821

# idm schema 数据库(role=idm)。设 IDM_DB_HOST 即 idm 走 pg(读 seed 的 superadmin 等);不设 = 内存。
# 字段默认:port 5432 / database xchangeai / user idm / password pwd / sslmode disable。
# IDM_DB_HOST=localhost
# IDM_DB_PORT=5821

# content schema 数据库(role=content)。设 CONTENT_DB_HOST 即 content/object 元数据走 pg;不设 = 内存。
# 字段默认:port 5432 / database xchangeai / user content / password pwd / sslmode disable。
# CONTENT_DB_HOST=localhost
# CONTENT_DB_PORT=5821

# 对象存储(content 的字节后端;元数据进上面的 pg)。设 S3_ENDPOINT 即走 minio/S3;不设 = 内存 backend。
# dev 连本地 compose minio 用主机端口:http://localhost:9862(即 MINIO_PORT)。
# 单域名要求:启用 presign(preview/download 307)时,S3_ENDPOINT 必须**浏览器可达**
# (host dev 用 localhost:9862 即可;compose 见 docker-compose.yml 的 minio.localhost 方案)。
# 其余默认:bucket content / access minio / secret minio12345 / region us-east-1(与 compose minio 对齐)。
# S3_ENDPOINT=http://localhost:9862
# S3_BUCKET=content
# S3_ACCESS_KEY=minio
# S3_SECRET_KEY=minio12345
# S3_REGION=us-east-1

# widget 事件总线(SSE)。选择链:设 NATS_URL → NATS(多实例默认);没设有 APP_DB_HOST → PG
# LISTEN/NOTIFY 退路;都没有 → 内存(单实例)。dev 连本地 compose nats 用主机端口 NATS_PORT(默认 2224)。
# NATS_URL=nats://localhost:2224

# 日志级别(tracing EnvFilter)。不设 = dev 默认 debug 全开。
# 注意:放进 .env 会同时影响本地 app(dotenvy 读它),想保留 dev debug 就别在 .env 设。
# RUST_LOG=info,xchangeai=debug

# 文件日志路径。不设 = 只 stdout(容器/生产)。dev 设成 logs/dev.log 即可在文件观察。
# LOG_FILE=logs/dev.log

# app 进程是否内嵌 idm。默认 true(单进程 Both);生产分进程设 false → 只挂 app。只认小写 true/false。
# IDM_EMBEDDED=true

# seed / mock 数据文件覆盖。不设 = 用编译期嵌入的 seed.toml / mock.toml。
# SEED_FILE=seed.toml
# MOCK_FILE=mock.toml

# ===== docker compose =====
# compose 用这些做 ${VAR} 替换,都有默认值(不设也能 up)。

# 运行环境:dev(默认)/staging/prod。prod → JSON 日志 + 不挂 /docs + CORS 走白名单。
# APP_ENV=dev
# prod CORS 允许的源(逗号分隔);dev/staging 走 permissive 不读此项。
# CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com

# pg 超级用户(dbhub DSN 引用;initdb 用它创建各 schema 的 role)
# POSTGRES_USER=xchangeai
# POSTGRES_PASSWORD=xchangeai
# POSTGRES_DB=xchangeai

# 各 schema 的 role(名 = schema 名)与密码,各走独立变量;密码暂统一 pwd。
# app 容器与迁移都用对应 role 连接(role 的 search_path 指向同名 schema,不写 schema 前缀)。
# APP_DB_USER=app
# APP_DB_PASSWORD=pwd
# IDM_DB_USER=idm
# IDM_DB_PASSWORD=pwd
# CONTENT_DB_USER=content
# CONTENT_DB_PASSWORD=pwd

# minio 凭据与桶名(compose 的 minio/minio-init 服务 + app 的 S3_ACCESS_KEY/S3_SECRET_KEY 都取这)
# MINIO_USER=minio
# MINIO_PASSWORD=minio12345
# S3_BUCKET=content

# 主机映射端口
# APP_PORT=6453
# IDM_PORT=6454
# DBHUB_PORT=3777
# PG_PORT=5821
# NGINX_PORT=80
# MINIO_PORT=9862
# MINIO_CONSOLE_PORT=9863
# NATS_PORT=2224
