/target
.env
/logs

# transient agent worktrees
.claude/worktrees/

# JWT 密钥:默认拒(私钥绝不入库)。只放行入库的 dev 对 + README —— 任意命名的
# 生成钥(just gen-keys 的 prod-ed25519.* 等)自动被挡,不靠记得改规则(fail-safe)。
/keys/*
!/keys/dev-ed25519.pem
!/keys/dev-ed25519.pub.pem
!/keys/README.md

# 生产部署包(build-and-export.sh 产出):镜像 tar + 明文密码 .env + 私钥,绝不入库。
/prod/

# prod/staging seed 账号文件(含真密码,绝不入库):任意 seed.<env>.toml 自动挡,
# 只放行 .example 模板。(入库的 dev 默认 `seed.toml` 不匹配 `seed.*.toml`,不受影响。)
/seed.*.toml
!/seed.*.toml.example
