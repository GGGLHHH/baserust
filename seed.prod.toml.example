# 生产 seed 账号模板 —— **复制成 `seed.prod.toml`(已被 .gitignore 挡,绝不入库),填真密码**。
#
# 【容器 / prod 主路径】把本文件(填好真密码后)作为 secret 挂进容器,进程启动时自动幂等建号:
#   - 挂载:k8s secret / docker secret / volume → 容器内某路径,如 /run/secrets/seed.prod.toml
#   - 设 env:SEED_FILE=/run/secrets/seed.prod.toml
#   - idm 进程启动即 seed(seed_on_start:prod 检测到 SEED_FILE 才开;无则不建号,防弱默认)
#   容器镜像无 just/cargo —— 不依赖任何外部命令,建号发生在二进制启动时。
#
# 【本地 / 一次性】prod-like 手动 seed:
#   cp seed.prod.toml.example seed.prod.toml && vi seed.prod.toml   # 填强密码
#   SEED_FILE=seed.prod.toml just seed-prod
#
# 只放**账号**(实例数据 + 密码)。角色集 / 权限集是代码闭集(src/infra/authz.rs 的
# RoleName / Perm),不在此;role→权限默认由启动时 seed_authz 幂等灌 app 表(prod+dev 都跑)。
# 账号引用的 role 必须是 RoleName 已知变体(superadmin/admin/user),拼错启动即挂。
#
# 密码存库经 Argon2 哈希;幂等 —— 账号已存在则跳过,重启不冲掉运维轮换过的密码。

[[accounts]]
username = "superadmin"
email = "superadmin@your-domain.example"
password = "CHANGE_ME_strong_random_password" # ← 换成强随机密码
roles = ["superadmin"]

# 按需增删下面的默认账号;prod 通常只保留一个引导超管,其余经后台创建。
# [[accounts]]
# username = "admin"
# password = "CHANGE_ME"
# roles = ["admin"]
